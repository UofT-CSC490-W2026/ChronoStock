# Copy this file to prod.tfvars and replace every placeholder before applying.
# Do not commit the populated file.

key_name = "your-prod-key-pair"

# Optional infrastructure sizing overrides.
ec2_instance_type         = "t3.small"
ec2_root_volume_size      = 16
ec2_root_volume_type      = "gp3"
ec2_root_volume_encrypted = true
db_instance_class         = "db.t3.small"
db_allocated_storage      = 50

db_password = "replace-with-a-strong-prod-db-password"
db_name     = "stock_pipeline"
db_username = "postgres"

bucket_name                 = "your-unique-chronostock-prod-bucket"
pipeline_source_bucket_name = "your-unique-chronostock-prod-source-bucket"

polygon_api_key = "replace-with-your-polygon-api-key"
llm_api_key     = "replace-with-your-llm-api-key"
fred_api_key    = "replace-with-your-fred-api-key"
aws_bearer_token_bedrock = "replace-with-your-bedrock-api-key"
bedrock_model_id         = "us.anthropic.claude-haiku-4-5-20251001-v1:0"
llm_model       = "deepseek-chat"
llm_base_url    = "https://api.deepseek.com"

monthly_event_tickers = "TSLA,GOOGL,META,MSFT,NVDA"

secret_name    = "your-chronostock-prod-secret"
jwt_secret_key = "replace-with-a-long-random-jwt-secret"
frontend_url   = "https://your-frontend-domain.example"
certbot_email  = "your-email@example.com"
