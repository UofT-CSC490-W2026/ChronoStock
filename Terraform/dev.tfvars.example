# Copy this file to dev.tfvars and replace every placeholder before applying.

# Existing AWS EC2 key pair name.
key_name = "your-dev-key-pair"

# RDS configuration.
db_password = "replace-with-a-strong-dev-db-password"
db_name     = "stock_pipeline"
db_username = "postgres"

# Globally unique S3 bucket names.
bucket_name                 = "your-unique-chronostock-dev-bucket"
pipeline_source_bucket_name = "your-unique-chronostock-dev-source-bucket"

# Runtime secrets and API access.
polygon_api_key = "replace-with-your-polygon-api-key"
llm_api_key     = "replace-with-your-llm-api-key"
fred_api_key    = "replace-with-your-fred-api-key"
aws_bearer_token_bedrock = "replace-with-your-bedrock-api-key"
bedrock_model_id         = "us.anthropic.claude-haiku-4-5-20251001-v1:0"
llm_model       = "deepseek-chat"
llm_base_url    = "https://api.deepseek.com"

# Monthly event pipeline input tickers.
monthly_event_tickers = "TSLA,GOOGL,META,MSFT,NVDA"

# Secrets Manager / backend config.
secret_name    = "your-chronostock-dev-secret"
jwt_secret_key = "replace-with-a-long-random-jwt-secret"
frontend_url   = "http://localhost:3000"
certbot_email  = "your-email@example.com"
