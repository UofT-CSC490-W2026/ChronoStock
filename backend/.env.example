# Copy this to .env for local development.
# In AWS, set these as ECS task environment variables or via Secrets Manager.

# URL of the deployed frontend (for CORS)
FRONTEND_URL=https://your-frontend-domain.com

# ── Cache ─────────────────────────────────────────────────────────────────────
# "local"  → JSON files written to LOCAL_CACHE_DIR on disk (default for dev)
# "s3"     → JSON files written to S3_CACHE_BUCKET (set this in AWS)
# "redis"  → JSON values written to REDIS_URL
CACHE_BACKEND=local
LOCAL_CACHE_DIR=./local

# Only required when CACHE_BACKEND=s3
S3_CACHE_BUCKET=your-s3-bucket-name
S3_CACHE_PREFIX=chronostock/cache/

# Only required when CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_PREFIX=chronostock/cache/
# Redis key TTL in seconds (default: 24h). Set 0 to disable key expiration.
REDIS_CACHE_TTL_SECONDS=86400
# Hard cap on number of Redis cache keys. Oldest keys are evicted first.
# Set 0 to disable max-key eviction.
REDIS_MAX_KEYS=5000

# ── Database ──────────────────────────────────────────────────────────────────
# "sqlite"   → local SQLite file at SQLITE_PATH (default for dev)
# "postgres" → connect to DATABASE_URL (use for AWS RDS)
DB_BACKEND=sqlite
SQLITE_PATH=./data/chronostock.db
DATABASE_URL=postgresql://user:password@localhost:5432/chronostock

# ── Email (password reset) ────────────────────────────────────────────────────
# "log" → prints reset link to stdout (dev default, no setup needed)
# "ses" → sends via AWS SES (requires SES_FROM_EMAIL + verified sender in AWS)
EMAIL_BACKEND=log
SES_FROM_EMAIL=no-reply@yourdomain.com

# Auth
JWT_SECRET_KEY='replace-this-with-a-long-random-secret'

# SEC EDGAR — required by SEC's fair-access policy; use a real email
SEC_USER_AGENT_EMAIL=your-email@example.com
